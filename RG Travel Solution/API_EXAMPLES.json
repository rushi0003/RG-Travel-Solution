  "commonErrorsAndSolutions": [
    {
      "error": "Connection refused",
      "cause": "Backend not running",
      "solution": "Run: python app.py"
    },
    {
      "error": "401 Unauthorized",
      "cause": "Invalid token or expired session",
      "solution": "Login again and get new token"
    },
    {
      "error": "400 Bad Request",
      "cause": "Invalid input data",
      "solution": "Check request body matches schema"
    },
    {
      "error": "404 Not Found",
      "cause": "Resource doesn't exist",
      "solution": "Verify ID exists in database"
    },
    {
      "error": "500 Internal Server Error",
      "cause": "Server-side error",
      "solution": "Check backend logs for details"
    }
  ]
}
