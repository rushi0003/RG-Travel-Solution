    "createTrip": {
      "name": "Create Trip with Auto Grouping Example",
      "description": "Create trip and automatically group employees",
      "curl": {
        "method": "POST",
        "path": "/api/admin/trips/create-and-group",
        "command": "curl -X POST http://localhost:5000/api/admin/trips/create-and-group \\\n  -H 'Authorization: Bearer YOUR_ADMIN_TOKEN' \\\n  -H 'Content-Type: application/json' \\\n  -d '{\n    \"route_no\": \"RG20260201A\",\n    \"operation\": \"pickup\",\n    \"trip_time\": \"08:00\",\n    \"vehicle_type\": \"4\",\n    \"max_employees\": 15,\n    \"grouping_strategy\": \"distance\"\n  }'",
        "response": {
          "success": true,
          "data": {
            "trip_id": 1,
            "route_no": "RG20260201A",
            "groups": [
              {
                "group_id": 1,
                "driver_id": 5,
                "driver_name": "Demo Driver 1",
                "employees": [
                  {
                    "id": 1,
                    "name": "Demo Employee 1",
                    "mobile": "0000100001"
                  }
                ],
                "total": 4,
                "vehicle_type": "4"
              }
            ],
            "total_groups": 4,
            "total_employees": 15
          }
        }
      },
      "python": {
        "code": "import requests\nimport json\n\ntoken = 'YOUR_ADMIN_TOKEN'\nheaders = {\n    'Authorization': f'Bearer {token}',\n    'Content-Type': 'application/json'\n}\npayload = {\n    'route_no': 'RG20260201A',\n    'operation': 'pickup',\n    'trip_time': '08:00',\n    'vehicle_type': '4',\n    'max_employees': 15,\n    'grouping_strategy': 'distance'\n}\nresponse = requests.post(\n    'http://localhost:5000/api/admin/trips/create-and-group',\n    headers=headers,\n    json=payload\n)\nprint(json.dumps(response.json(), indent=2))",
        "output": "Trip created with 4 groups and 15 employees"
      }
    },
