  "testingWorkflow": {
    "step1": {
      "name": "Verify Server Running",
      "command": "curl -X GET http://localhost:5000/api/health",
      "expectedStatus": 200,
      "expectedData": {
        "success": true,
        "data": {
          "status": "ok"
        }
      }
    },
    "step2": {
      "name": "Seed Test Data",
      "commands": [
        "curl -X POST http://localhost:5000/api/seed/admin",
        "curl -X POST http://localhost:5000/api/seed/drivers",
        "curl -X POST http://localhost:5000/api/seed/employees"
      ],
      "expectedStatus": 201,
      "note": "Save credentials for login tests"
    },
    "step3": {
      "name": "Test Admin Login",
      "command": "curl -X POST http://localhost:5000/api/auth/admin/login -d '{\"mobile\": \"0000000001\", \"password\": \"admin123\"}'",
      "expectedStatus": 200,
      "note": "Copy token for next steps"
    },
    "step4": {
      "name": "Create Trip",
      "command": "curl -X POST http://localhost:5000/api/admin/trips/create-and-group -H 'Authorization: Bearer <ADMIN_TOKEN>'",
      "expectedStatus": 201,
      "note": "Trip should be created with auto-grouped employees"
    },
    "step5": {
      "name": "Test Driver Login",
      "command": "curl -X POST http://localhost:5000/api/auth/driver/login -d '{\"mobile\": \"0000001001\", \"password\": \"driver123\"}'",
      "expectedStatus": 200
    },
    "step6": {
      "name": "Test Employee Login",
      "command": "curl -X POST http://localhost:5000/api/auth/employee/login -d '{\"mobile\": \"0000100001\", \"password\": \"emp123\"}'",
      "expectedStatus": 200
    }
  },
