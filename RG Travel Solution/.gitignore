*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/

.venv/
venv/
env/
ENV/

*.egg-info/
dist/

# -------------------------
# Environment / secrets
# -------------------------
.env
.env.*
!.env.example

*.key
*.pem
*.crt
*.p12
*.pfx
rg_travel_backend/config/keys.local.py
rg_travel_backend/config/secret*.py

# -------------------------
# SQLite databases
# Keep schema and migrations, ignore runtime DB files.
# -------------------------
*.db
*.sqlite
*.sqlite3
*.db-*
*.sqlite-*
*.bak
*.bak_*
*.backup
*.backup_*

!DATABASE_SCHEMA.json
!rg_travel_backend/db/schema.sql
!rg_travel_backend/db/*.sql
!rg_travel_backend/db/migrations/*.sql

