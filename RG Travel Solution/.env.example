# =========================================================
# RG Travel Solution - .env.example
# Copy this file to ".env" and fill values.
# DO NOT commit .env (it's ignored by .gitignore)
# =========================================================

# -------------------------
# Flask Server Settings
# -------------------------
RG_DEBUG=1
RG_HOST=0.0.0.0
RG_PORT=5000

# -------------------------
# CORS (Flutter + Web)
# -------------------------
# Use "*" for development.
# For production, restrict to your domains:
# Example: http://localhost:3000,https://yourdomain.com
RG_CORS_ENABLED=1
RG_CORS_ORIGINS=*

# -------------------------
# Database
# -------------------------
# If empty -> backend/db/__init__.py uses default: backend/rg_travel.db
# Example:
# RG_DB_PATH=C:\Users\HP\Desktop\RG_TRAVEL_SOLUTION\backend\rg_travel.db
RG_DB_PATH=

# Allow /api/db/reset (DANGEROUS). Only set 1 in development.
RG_ALLOW_DB_RESET=0

# -------------------------
# Security / Tokens
# -------------------------
# Flask secret key (set a long random string)
RG_SECRET_KEY=change-this-to-a-long-random-secret

# Token expiry in minutes (default 1440 = 24 hours)
RG_TOKEN_TTL_MINUTES=1440

# OTP expiry in minutes (default 5)
RG_OTP_EXPIRY_MINUTES=5

# -------------------------
# Google Maps (Routing/Distance/Geocoding)
# -------------------------
# Put your real key here:
RG_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# -------------------------
# Feature Flags (Dev APIs)
# -------------------------
# Enable /api/config/* endpoints (keys health/runtime/reload)
RG_ENABLE_CONFIG_API=0

# Enable /api/settings/* endpoints (settings health/runtime/reload)
RG_ENABLE_SETTINGS_API=0

# Enable /api/*/seed endpoints (seed admin/driver/employee)
RG_ENABLE_SEED_API=1

# -------------------------
# Grouping Limits
# -------------------------
# Group size based on vehicle type (4 or 6)
RG_MAX_GROUP_SIZE_4=4
RG_MAX_GROUP_SIZE_6=6

# Max employees per trip (safe upper cap)
RG_MAX_EMPLOYEE_PER_TRIP=6

# -------------------------
# Notes
# -------------------------
# Android Emulator Flutter base URL:
#   http://10.0.2.2:5000
#
# If Flutter shows "Failed to fetch":
# 1) backend running?  GET /api/utils/ping
# 2) correct base URL? http://10.0.2.2:5000
# 3) API prefix used?  /api/...
